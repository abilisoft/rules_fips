use_repo(
    foreign_tools,
    "cmake_3.31.8_toolchains",
    "cmake_src",
    "gettext_runtime",
    "glib_dev",
    "glib_src",
    "gnumake_src",
    "meson_src",
    "ninja_1.13.0_toolchains",
    "ninja_build_src",
    "pkgconfig_src",
    "rules_foreign_cc_framework_toolchains",
)

fips_sources = use_extension("//fips:extensions.bzl", "fips_sources")
use_repo(
    fips_sources,
    "boringssl_src",
    "elixir_src",
    "linux_amd64_sysroot",
    "linux_arm64_sysroot",
    "musl_src",
    "openssl_core_src",
    "openssl_fips_src",
    "otp_src",
)

