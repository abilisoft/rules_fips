#!/bin/sh
set -eu

fips_root=${FIPS_ELIXIR_ROOT:-/opt/fips-elixir}
ERL_ROOTDIR=${fips_root}/lib/erlang
export ERL_ROOTDIR
fips_module=${fips_root}/lib/ossl-modules/fips.so
fips_runtime_dir=$(mktemp -d "${TMPDIR:-/tmp}/fips-elixir.XXXXXX")
fips_module_conf=${fips_runtime_dir}/fipsmodule.cnf
fips_install_log=${fips_runtime_dir}/fipsinstall.log

if [ ! -r "${fips_module}" ]; then
    echo "OpenSSL FIPS provider not found: ${fips_module}" >&2
    exit 78
fi

if ! OPENSSL_CONF=/dev/null \
    OPENSSL_MODULES=${fips_root}/lib/ossl-modules \
        "${fips_root}/bin/openssl" fipsinstall \
            -module "${fips_module}" \
            -out "${fips_module_conf}" \
            -pedantic >"${fips_install_log}" 2>&1
then
    cat "${fips_install_log}" >&2
    exit 78
fi

export OPENSSL_CONF=${fips_root}/ssl/openssl-fips.cnf
export OPENSSL_MODULES=${fips_root}/lib/ossl-modules
export FIPS_MODULE_CONF=${fips_module_conf}

ERL_AFLAGS="${ERL_AFLAGS:+${ERL_AFLAGS} }-pa ${fips_root}/lib/fips_boot/ebin -crypto fips_mode true -s fips_boot verify"
export ERL_AFLAGS

exec "${fips_root}/bin/elixir.real" "$@"
